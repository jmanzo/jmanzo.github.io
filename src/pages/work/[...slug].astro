---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("work");
  return items
    .filter((item) => !item.data.url)
    .map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Base title={item.data.title} description={item.data.description}>
  <article class="max-w-2xl mx-auto px-6 pt-16 pb-16">
    <p class="text-xs uppercase tracking-widest text-[var(--color-muted)] mb-3">
      <a href="/work/" class="no-underline">Work</a> · {item.data.year}
    </p>
    <h1
      class="text-3xl sm:text-4xl font-semibold tracking-tight mb-3"
      style="font-family: var(--font-serif);"
    >
      {item.data.title}
    </h1>
    <p class="text-[var(--color-muted)] leading-relaxed mb-8">
      {item.data.description}
    </p>
    <div class="prose-body">
      <Content />
    </div>
  </article>
</Base>
