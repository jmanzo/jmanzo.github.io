---
import Base from "../layouts/Base.astro";
---

<Base title="Not found">
  <section class="max-w-2xl mx-auto px-6 pt-24 pb-16 text-center">
    <p
      class="text-xs uppercase tracking-widest text-[var(--color-muted)] mb-3"
    >
      404
    </p>
    <h1
      class="text-3xl sm:text-4xl font-semibold tracking-tight mb-4"
      style="font-family: var(--font-serif);"
    >
      Nothing here.
    </h1>
    <p class="text-[var(--color-muted)]">
      The page you were looking for doesn't exist.
      <a href="/">Head back home →</a>
    </p>
  </section>
</Base>
