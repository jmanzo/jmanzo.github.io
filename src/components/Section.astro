---
interface Props {
  title?: string;
  eyebrow?: string;
  class?: string;
}

const { title, eyebrow, class: className = "" } = Astro.props;
---

<section class:list={["max-w-2xl mx-auto px-6 py-12", className]}>
  {
    eyebrow && (
      <p class="text-xs uppercase tracking-widest text-[var(--color-muted)] mb-2">
        {eyebrow}
      </p>
    )
  }
  {
    title && (
      <h2 class="text-2xl font-semibold tracking-tight mb-6 font-[var(--font-serif)]">
        {title}
      </h2>
    )
  }
  <slot />
</section>
